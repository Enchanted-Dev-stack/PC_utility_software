{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["jest", "node"],
    "outDir": "dist"
  },
  "include": ["apps/**/*.ts", "apps/**/*.tsx", "shared/**/*.ts", "tests/**/*.ts"]
}
